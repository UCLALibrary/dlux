{
	"name": "Django",
	"dockerComposeFile": "../docker-compose.yml",
	"service": "django",
	"workspaceFolder": "/home/django/django_app",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"redhat.vscode-yaml"
			],
			"settings": {
				"editor.formatOnSave": true,
				"python.analysis.typeCheckingMode": "strict",
				"python.defaultInterpreterPath": "/home/django/django_app/.venv/bin/python",
				"python.terminal.activateEnvInCurrentTerminal": false, // very annoying; rely on $PATH instead
				"python.testing.unittestArgs": [
					"-v",
					"-s",
					".",
					"-p",
					"test*.py"
				],
				"python.testing.pytestEnabled": false,
				"python.testing.unittestEnabled": true,
				"ruff.configurationPreference": "filesystemFirst",
				"ruff.enable": true,
				"[python]": {
					"editor.codeActionsOnSave": {
						"source.fixAll": "explicit",
						"source.organizeImports": "never" // ruff handles it
					},
					"editor.defaultFormatter": "charliermarsh.ruff"
				}
			}
		}
	}
}