{
	"name": "Django",
	"dockerComposeFile": "../docker-compose.yml",
	"service": "django",
	"workspaceFolder": "/home/django/django_app",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.mypy-type-checker",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"redhat.vscode-yaml"
			],
			"settings": {
				"editor.formatOnSave": true,
				"python.analysis.typeCheckingMode": "basic", // fallback for things that silently crash mypy
				"ruff.configurationPreference": "filesystemFirst",
				"ruff.enable": true,
				"[python]": {
					"editor.codeActionsOnSave": {
						"source.fixAll": "explicit",
						"source.organizeImports": "never"  // ruff handles it
					},
					"editor.defaultFormatter": "charliermarsh.ruff"
				}
			}
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/git": {},
		"ghcr.io/devcontainers/features/common-utils:2": {} // for ssh, to push to github
	}
}